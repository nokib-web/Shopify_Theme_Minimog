{% comment %}
  Section: Testimonials Carousel — Enhanced
  File: sections/testimonials-carousel.liquid
  Features:
    - 5 visible cards on desktop (2 faded side + 1 faded near-side + 1 highlighted center)
    - Product/image card support for center highlight
    - Fully responsive: desktop / tablet / mobile customization
    - Infinite loop with clone technique
    - Autoplay, arrows, dots, touch/swipe
{% endcomment %}

<style>
  #tc-{{ section.id }} {
    --tc-section-bg:          {{ section.settings.section_bg }};
    --tc-section-pad-v:       {{ section.settings.section_padding_v }}px;
    --tc-section-pad-h:       {{ section.settings.section_padding_h }}px;
    --tc-card-gap:            {{ section.settings.card_gap }}px;
    --tc-card-radius:         {{ section.settings.card_radius }}px;
    --tc-card-bg:             {{ section.settings.card_bg }};
    --tc-card-border:         {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    --tc-card-shadow:         {{ section.settings.card_shadow }};
    --tc-card-pad-v:          {{ section.settings.card_padding_v }}px;
    --tc-card-pad-h:          {{ section.settings.card_padding_h }}px;
    --tc-center-bg:           {{ section.settings.card_center_bg }};
    --tc-center-border:       {{ section.settings.card_center_border_width }}px solid {{ section.settings.card_center_border_color }};
    --tc-center-shadow:       {{ section.settings.card_center_shadow }};
    --tc-center-scale:        {{ section.settings.center_scale | divided_by: 100.0 }};
    --tc-side-opacity:        {{ section.settings.side_opacity | divided_by: 100.0 }};
    --tc-side2-opacity:       {{ section.settings.side2_opacity | divided_by: 100.0 }};
    --tc-side-blur:           {{ section.settings.side_blur }}px;
    --tc-side2-blur:          {{ section.settings.side2_blur }}px;
    --tc-side-scale:          {{ section.settings.side_scale | divided_by: 100.0 }};
    --tc-side2-scale:         {{ section.settings.side2_scale | divided_by: 100.0 }};
    --tc-arrow-size:          {{ section.settings.arrow_size }}px;
    --tc-arrow-bg:            {{ section.settings.arrow_bg }};
    --tc-arrow-border:        1px solid {{ section.settings.arrow_border_color }};
    --tc-arrow-color:         {{ section.settings.arrow_color }};
    --tc-arrow-hover-bg:      {{ section.settings.arrow_hover_bg }};
    --tc-arrow-hover-color:   {{ section.settings.arrow_hover_color }};
    --tc-dot-size:            {{ section.settings.dot_size }}px;
    --tc-dot-color:           {{ section.settings.dot_color }};
    --tc-dot-active:          {{ section.settings.dot_active_color }};
    --tc-transition:          {{ section.settings.transition_speed }}ms cubic-bezier(0.4,0,0.2,1);
  }

  .tc-section {
    background: var(--tc-section-bg);
    padding: var(--tc-section-pad-v) var(--tc-section-pad-h);
    overflow: hidden;
    position: relative;
  }

  /* ── Header ── */
  .tc-header {
    text-align: center;
    margin-bottom: {{ section.settings.header_gap }}px;
  }
  .tc-eyebrow {
    display: block;
    font-size: {{ section.settings.eyebrow_size }}px;
    color: {{ section.settings.eyebrow_color }};
    font-style: {{ section.settings.eyebrow_style }};
    letter-spacing: 0.05em;
    margin: 0 0 8px;
  }
  .tc-heading-wrap {
    position: relative;
    display: inline-block;
  }
  .tc-heading-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: {{ section.settings.heading_bg_size }}px;
    font-weight: 900;
    color: {{ section.settings.heading_bg_color }};
    opacity: {{ section.settings.heading_bg_opacity | divided_by: 100.0 }};
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: 0.06em;
    z-index: 0;
  }
  .tc-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0;
    position: relative;
    z-index: 1;
  }

  /* ── Carousel outer ── */
  .tc-carousel-outer {
    display: flex;
    align-items: center;
  }
  .tc-track-wrap {
    overflow: hidden;
    width: 100%;
    padding: 32px 0;
    margin: -32px 0;
    box-sizing: content-box;
  }
  .tc-track {
    display: flex;
    gap: var(--tc-card-gap);
    transition: transform var(--tc-transition);
    will-change: transform;
  }

  /* ── Card base ── */
  .tc-card {
    flex: 0 0 calc((100% - var(--tc-card-gap) * 4) / 5);
    background: var(--tc-card-bg);
    border: var(--tc-card-border);
    border-radius: var(--tc-card-radius);
    padding: var(--tc-card-pad-v) var(--tc-card-pad-h);
    box-shadow: var(--tc-card-shadow);
    position: relative;
    transition:
      transform var(--tc-transition),
      opacity var(--tc-transition),
      filter var(--tc-transition),
      box-shadow var(--tc-transition),
      background var(--tc-transition),
      border-color var(--tc-transition);

    /* Far-side default */
    opacity: var(--tc-side2-opacity);
    filter: blur(var(--tc-side2-blur)) brightness(0.55);
    transform: scale(var(--tc-side2-scale));
  }

  /* Near-side (index ±1 from center) */
  .tc-card.is-near {
    opacity: var(--tc-side-opacity);
    filter: blur(var(--tc-side-blur)) brightness(0.75);
    transform: scale(var(--tc-side-scale));
  }

  /* Center card */
  .tc-card.is-center {
    background: var(--tc-center-bg);
    border: var(--tc-center-border);
    box-shadow: var(--tc-center-shadow);
    transform: scale(var(--tc-center-scale));
    opacity: 1;
    filter: none;
    z-index: 2;
  }

  /* Center image (product/hero image) */
  .tc-card-hero {
    width: 100%;
    aspect-ratio: {{ section.settings.hero_aspect }};
    object-fit: cover;
    border-radius: calc(var(--tc-card-radius) - 4px);
    margin-bottom: {{ section.settings.hero_gap }}px;
    display: block;
  }

  /* ── Author row ── */
  .tc-author-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: {{ section.settings.author_gap }}px;
  }
  .tc-avatar {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid {{ section.settings.avatar_border_color }};
    flex-shrink: 0;
  }
  .tc-avatar-placeholder {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    background: {{ section.settings.avatar_placeholder_bg }};
    border: 2px solid {{ section.settings.avatar_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: {{ section.settings.avatar_size | divided_by: 2 }}px;
    color: {{ section.settings.card_border_color }};
  }
  .tc-author-name {
    font-size: {{ section.settings.name_size }}px;
    font-weight: {{ section.settings.name_weight }};
    color: {{ section.settings.name_color }};
    margin: 0 0 2px;
    line-height: 1.2;
  }
  .tc-author-role {
    font-size: {{ section.settings.role_size }}px;
    color: {{ section.settings.role_color }};
    margin: 0;
  }

  /* ── Stars ── */
  .tc-stars {
    display: flex;
    gap: 2px;
    margin-bottom: {{ section.settings.stars_gap }}px;
  }
  .tc-star        { font-size: {{ section.settings.star_size }}px; color: {{ section.settings.star_color }}; }
  .tc-star.empty  { color: {{ section.settings.star_empty_color }}; }

  /* ── Review ── */
  .tc-review {
    font-size: {{ section.settings.review_size }}px;
    color: {{ section.settings.review_color }};
    line-height: {{ section.settings.review_line_height }};
    margin: 0;
  }
  .tc-card.is-center .tc-review {
    font-size: {{ section.settings.center_review_size }}px;
    font-weight: {{ section.settings.center_review_weight }};
    color: {{ section.settings.center_review_color }};
  }

  /* ── Quote icon ── */
  .tc-quote-icon {
    position: absolute;
    top: {{ section.settings.quote_top }}px;
    right: {{ section.settings.quote_right }}px;
    font-size: {{ section.settings.quote_size }}px;
    color: {{ section.settings.quote_color }};
    opacity: 0.22;
    line-height: 1;
    pointer-events: none;
  }

  /* ── Arrows ── */
  .tc-arrow {
    background: var(--tc-arrow-bg);
    border: var(--tc-arrow-border);
    color: var(--tc-arrow-color);
    width: var(--tc-arrow-size);
    height: var(--tc-arrow-size);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    font-size: 18px;
    transition: background 0.2s, color 0.2s, transform 0.2s;
    z-index: 5;
    margin: 0 {{ section.settings.arrow_margin }}px;
  }
  .tc-arrow:hover {
    background: var(--tc-arrow-hover-bg);
    color: var(--tc-arrow-hover-color);
    transform: scale(1.1);
  }

  /* ── Dots ── */
  .tc-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: {{ section.settings.dots_margin_top }}px;
  }
  .tc-dot {
    width: var(--tc-dot-size);
    height: var(--tc-dot-size);
    border-radius: 50%;
    background: var(--tc-dot-color);
    opacity: 0.3;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s, transform 0.3s;
  }
  .tc-dot.active {
    opacity: 1;
    background: var(--tc-dot-active);
    transform: scale(1.35);
  }

  /* ── TABLET (769–1024px): show 3 cards ── */
  @media (min-width: 769px) and (max-width: {{ section.settings.tablet_breakpoint }}px) {
    .tc-card {
      flex: 0 0 calc((100% - var(--tc-card-gap) * 2) / 3);
      opacity: var(--tc-side-opacity);
      filter: blur({{ section.settings.tablet_side_blur }}px) brightness(0.7);
      transform: scale({{ section.settings.tablet_side_scale | divided_by: 100.0 }});
    }
    .tc-card.is-near {
      opacity: var(--tc-side-opacity);
      filter: blur({{ section.settings.tablet_side_blur }}px) brightness(0.7);
      transform: scale({{ section.settings.tablet_side_scale | divided_by: 100.0 }});
    }
    .tc-card.is-center {
      transform: scale({{ section.settings.tablet_center_scale | divided_by: 100.0 }});
      opacity: 1;
      filter: none;
    }
    .tc-arrow {
      {% if section.settings.hide_arrows_tablet %}display: none !important;{% endif %}
    }
  }

  /* ── MOBILE (≤768px): show 1 card centred, neighbours peek ── */
  @media (max-width: 768px) {
    .tc-section {
      padding: {{ section.settings.mobile_padding_v }}px {{ section.settings.mobile_padding_h }}px;
    }
    .tc-card {
      flex: 0 0 {{ section.settings.mobile_card_width }}%;
      opacity: var(--tc-side-opacity);
      filter: blur({{ section.settings.mobile_side_blur }}px) brightness(0.65);
      transform: scale({{ section.settings.mobile_side_scale | divided_by: 100.0 }});
    }
    .tc-card.is-near {
      opacity: var(--tc-side-opacity);
      filter: blur({{ section.settings.mobile_side_blur }}px) brightness(0.65);
      transform: scale({{ section.settings.mobile_side_scale | divided_by: 100.0 }});
    }
    .tc-card.is-center {
      transform: scale({{ section.settings.mobile_center_scale | divided_by: 100.0 }});
      opacity: 1;
      filter: none;
    }
    .tc-arrow { display: none !important; }
    .tc-heading { font-size: {{ section.settings.mobile_heading_size }}px; }
    .tc-eyebrow { font-size: {{ section.settings.mobile_eyebrow_size }}px; }
    .tc-review  { font-size: {{ section.settings.mobile_review_size }}px; }
    .tc-card.is-center .tc-review { font-size: {{ section.settings.mobile_center_review_size }}px; }
    .tc-avatar  { width: {{ section.settings.mobile_avatar_size }}px; height: {{ section.settings.mobile_avatar_size }}px; }
    .tc-author-name { font-size: {{ section.settings.mobile_name_size }}px; }
  }
</style>

<section class="tc-section" id="tc-{{ section.id }}">

  <!-- Header -->
  <div class="tc-header">
    {% if section.settings.eyebrow != blank %}
      <span class="tc-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <div class="tc-heading-wrap">
      {% if section.settings.show_heading_bg %}
        <span class="tc-heading-bg">{{ section.settings.heading }}</span>
      {% endif %}
      <h2 class="tc-heading">{{ section.settings.heading }}</h2>
    </div>
  </div>

  <!-- Carousel -->
  <div class="tc-carousel-outer">

    {% if section.settings.show_arrows %}
      <button class="tc-arrow" id="tc-prev-{{ section.id }}" aria-label="Previous">&#8592;</button>
    {% endif %}

    <div class="tc-track-wrap">
      <div class="tc-track" id="tc-track-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <div class="tc-card" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>

              {% if section.settings.show_quote_icon %}
                <span class="tc-quote-icon">&#8220;</span>
              {% endif %}

              {% if block.settings.hero_image != blank %}
                <img
                  class="tc-card-hero"
                  src="{{ block.settings.hero_image | image_url: width: 800 }}"
                  alt="{{ block.settings.hero_image_alt | default: block.settings.name }}"
                  loading="lazy"
                  width="800"
                >
              {% endif %}

              <div class="tc-author-row">
                {% if block.settings.avatar != blank %}
                  <img class="tc-avatar" src="{{ block.settings.avatar | image_url: width: 120 }}" alt="{{ block.settings.name }}" width="{{ section.settings.avatar_size }}" height="{{ section.settings.avatar_size }}" loading="lazy">
                {% else %}
                  <div class="tc-avatar-placeholder">👤</div>
                {% endif %}
                <div>
                  <p class="tc-author-name">{{ block.settings.name }}</p>
                  <p class="tc-author-role">{{ block.settings.role }}</p>
                </div>
              </div>

              {% if section.settings.show_stars %}
                <div class="tc-stars">
                  {% assign rating = block.settings.rating %}
                  {% for i in (1..5) %}
                    {% if i <= rating %}<span class="tc-star">★</span>
                    {% else %}<span class="tc-star empty">★</span>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              <p class="tc-review">{{ block.settings.review }}</p>

            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.show_arrows %}
      <button class="tc-arrow" id="tc-next-{{ section.id }}" aria-label="Next">&#8594;</button>
    {% endif %}

  </div>

  {% if section.settings.show_dots %}
    <div class="tc-dots" id="tc-dots-{{ section.id }}"></div>
  {% endif %}

</section>

<script>
(function () {
  var sid         = '{{ section.id }}';
  var track       = document.getElementById('tc-track-' + sid);
  var prevBtn     = document.getElementById('tc-prev-' + sid);
  var nextBtn     = document.getElementById('tc-next-' + sid);
  var dotsWrap    = document.getElementById('tc-dots-' + sid);
  var autoDelay   = {{ section.settings.autoplay_speed }};
  var autoEnabled = {{ section.settings.autoplay }};
  var tabletBp    = {{ section.settings.tablet_breakpoint }};
  var autoTimer, isTransitioning = false;

  if (!track) return;

  /* ── Breakpoint helpers ── */
  function isMobile()  { return window.innerWidth <= 768; }
  function isTablet()  { return window.innerWidth > 768 && window.innerWidth <= tabletBp; }
  function isDesktop() { return window.innerWidth > tabletBp; }

  /* visibleCount: how many cards show at once per breakpoint */
  function visibleCount() {
    if (isMobile())  return 1;
    if (isTablet())  return 3;
    return 5;
  }

  /* The center-slot offset from the left-slot index */
  function centerOffset() { return Math.floor(visibleCount() / 2); }

  /* ── Collect original cards ── */
  var origCards = Array.from(track.querySelectorAll('.tc-card'));
  var total     = origCards.length;
  if (total === 0) return;

  /* ── Clone for infinite loop ── */
  var cloneCount = 5; // enough for 5-card view

  var prependClones = origCards.slice(-cloneCount).map(function (c) {
    var cl = c.cloneNode(true);
    cl.setAttribute('aria-hidden', 'true');
    cl.removeAttribute('data-index');
    return cl;
  });
  var appendClones = origCards.slice(0, cloneCount).map(function (c) {
    var cl = c.cloneNode(true);
    cl.setAttribute('aria-hidden', 'true');
    cl.removeAttribute('data-index');
    return cl;
  });

  prependClones.forEach(function (c) { track.insertBefore(c, track.firstChild); });
  appendClones.forEach(function (c) { track.appendChild(c); });

  /*
    Layout after cloning:
    [clone‑last‑5] [original 0..N-1] [clone‑first‑5]
    Indices 0..cloneCount-1 = prepend clones
    Indices cloneCount..cloneCount+total-1 = real cards
    current = left-slot index; center slot = current + centerOffset()
  */
  var current = cloneCount;

  /* ── Build dots ── */
  if (dotsWrap) {
    origCards.forEach(function (_, i) {
      var d = document.createElement('button');
      d.className = 'tc-dot';
      d.setAttribute('aria-label', 'Go to slide ' + (i + 1));
      d.addEventListener('click', function () { resetAuto(); goTo(cloneCount + i - centerOffset()); });
      dotsWrap.appendChild(d);
    });
  }

  /* ── Helpers ── */
  function allCards() { return Array.from(track.querySelectorAll('.tc-card')); }

  function getCardWidth() {
    var cards = allCards();
    if (!cards[0]) return 0;
    var gap = parseFloat(window.getComputedStyle(track).gap) || {{ section.settings.card_gap }};
    return cards[0].offsetWidth + gap;
  }

  function getTranslateX(idx) {
    var cw = getCardWidth();
    if (isMobile()) {
      var wrapWidth = track.parentElement.offsetWidth;
      var cardEl    = allCards()[0];
      var cardWidth = cardEl ? cardEl.offsetWidth : cw;
      return (cw * idx) - (wrapWidth - cardWidth) / 2;
    }
    return cw * idx;
  }

  function updateStates() {
    var co = centerOffset();
    var ci = current + co; // center card absolute index in full (cloned) array
    allCards().forEach(function (c, i) {
      c.classList.remove('is-center', 'is-near');
      var dist = Math.abs(i - ci);
      if (dist === 0) c.classList.add('is-center');
      else if (dist === 1) c.classList.add('is-near');
    });
  }

  function updateDots() {
    if (!dotsWrap) return;
    var co = centerOffset();
    var realIdx = ((current + co - cloneCount) % total + total) % total;
    dotsWrap.querySelectorAll('.tc-dot').forEach(function (d, i) {
      d.classList.toggle('active', i === realIdx);
    });
  }

  function jumpTo(idx) {
    track.style.transition = 'none';
    track.style.transform  = 'translateX(-' + getTranslateX(idx) + 'px)';
    current = idx;
    updateStates();
    updateDots();
  }

  function goTo(idx) {
    if (isTransitioning) return;
    isTransitioning = true;
    current = idx;
    track.style.transition = 'transform {{ section.settings.transition_speed }}ms cubic-bezier(0.4,0,0.2,1)';
    track.style.transform  = 'translateX(-' + getTranslateX(current) + 'px)';
    updateStates();
    updateDots();
  }

  track.addEventListener('transitionend', function () {
    isTransitioning = false;
    if (current >= cloneCount + total) jumpTo(current - total);
    else if (current < cloneCount)     jumpTo(current + total);
  });

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  if (nextBtn) nextBtn.addEventListener('click', function () { resetAuto(); next(); });
  if (prevBtn) prevBtn.addEventListener('click', function () { resetAuto(); prev(); });

  /* ── Autoplay ── */
  function startAuto() {
    if (!autoEnabled && !isMobile()) return;
    autoTimer = setInterval(next, autoDelay);
  }
  function resetAuto() { clearInterval(autoTimer); startAuto(); }

  /* ── Touch / Swipe ── */
  var touchStartX = 0, touchStartY = 0;
  track.addEventListener('touchstart', function (e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  track.addEventListener('touchend', function (e) {
    var dx = touchStartX - e.changedTouches[0].clientX;
    var dy = touchStartY - e.changedTouches[0].clientY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      resetAuto();
      dx > 0 ? next() : prev();
    }
  }, { passive: true });

  /* ── Keyboard ── */
  document.getElementById('tc-' + sid).addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  { resetAuto(); prev(); }
    if (e.key === 'ArrowRight') { resetAuto(); next(); }
  });

  /* ── Resize ── */
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      clearInterval(autoTimer);
      jumpTo(current);
      startAuto();
    }, 100);
  });

  /* ── Init ── */
  jumpTo(cloneCount);
  startAuto();
})();
</script>

{% schema %}
{
  "name": "Testimonials Carousel",
  "tag": "div",
  "settings": [
    { "type": "header", "content": "🎨 Section" },
    { "type": "color",  "id": "section_bg", "label": "Section background", "default": "#0a0a0a" },
    { "type": "range",  "id": "section_padding_v", "label": "Vertical padding", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 72 },
    { "type": "range",  "id": "section_padding_h", "label": "Horizontal padding", "min": 0,  "max": 80,  "step": 4, "unit": "px", "default": 20 },

    { "type": "header", "content": "✏️ Header Text" },
    { "type": "text",   "id": "eyebrow", "label": "Eyebrow text", "default": "What our customers say" },
    { "type": "color",  "id": "eyebrow_color", "label": "Eyebrow color", "default": "#f6df83" },
    { "type": "range",  "id": "eyebrow_size", "label": "Eyebrow font size", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 14 },
    { "type": "select", "id": "eyebrow_style", "label": "Eyebrow style", "default": "italic", "options": [{"value":"normal","label":"Normal"},{"value":"italic","label":"Italic"}] },
    { "type": "text",   "id": "heading", "label": "Heading", "default": "Testimonials" },
    { "type": "color",  "id": "heading_color", "label": "Heading color", "default": "#f6df83" },
    { "type": "range",  "id": "heading_size", "label": "Heading font size", "min": 24, "max": 80, "step": 2, "unit": "px", "default": 48 },
    { "type": "select", "id": "heading_weight", "label": "Heading weight", "default": "700", "options": [{"value":"400","label":"Regular"},{"value":"600","label":"Semibold"},{"value":"700","label":"Bold"},{"value":"900","label":"Black"}] },
    { "type": "checkbox","id": "show_heading_bg",  "label": "Show watermark behind title", "default": true },
