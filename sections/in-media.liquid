<section id="im-testi-{{ section.id }}" class="in-media-testi-wrapper">
  <div class="lt-inner">

    <!-- LEFT PANEL -->
    <div class="lt-left">
      {%- if sec.eyebrow != blank -%}
        <span class="lt-eyebrow">{{ sec.eyebrow }}</span>
      {%- endif -%}

      {%- if sec.heading != blank -%}
        <h2 class="lt-heading">{{ sec.heading }}</h2>
      {%- endif -%}

      {%- if sec.description != blank -%}
        <p class="lt-desc">{{ sec.description }}</p>
      {%- endif -%}

      {%- assign stat_blocks = section.blocks | where: 'type', 'stat' -%}
      {%- if stat_blocks.size > 0 -%}
        <div class="lt-stats">
          {%- for block in stat_blocks -%}
            <div class="lt-stat" {{ block.shopify_attributes }}>
              <span class="lt-stat__num">{{ block.settings.number }}</span>
              <span class="lt-stat__label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- RIGHT PANEL -->
    <div class="lt-right">
      {%- assign testi_blocks = section.blocks | where: 'type', 'testimonial' -%}
      {%- for block in testi_blocks -%}
        {%- assign card_index = forloop.index0 -%}
        {%- assign limit = sec.initial_visible_cards -%}
        {%- if limit > 0 and card_index >= limit -%}
          {%- assign extra_class = ' lt-card--hidden' -%}
        {%- else -%}
          {%- assign extra_class = '' -%}
        {%- endif -%}
        <div class="lt-card{{ extra_class }}" {{ block.shopify_attributes }}>

          <!-- Author -->
          <div class="lt-card__author">
            <div class="lt-card__avatar">
              {%- if block.settings.avatar != blank -%}
                {{
                  block.settings.avatar
                  | image_url: width: 120
                  | image_tag: loading: 'lazy', alt: block.settings.name
                }}
              {%- else -%}
                <span class="lt-card__avatar-initials">
                  {{- block.settings.name | slice: 0, 1 | upcase -}}
                </span>
              {%- endif -%}
            </div>
            <div class="lt-card__meta">
              {%- if block.settings.name != blank -%}
                <p class="lt-card__name">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <p class="lt-card__role">{{ block.settings.role }}</p>
              {%- endif -%}
              {%- if block.settings.review_date != blank -%}
                <p class="lt-card__date">{{ block.settings.review_date }}</p>
              {%- endif -%}
            </div>
          </div>

          <!-- Meta row: source + verified + product tag -->
          {%- if block.settings.review_source != 'none' or block.settings.show_verified or block.settings.product_tag != blank -%}
            <div class="lt-card__meta-row">
              {%- if block.settings.review_source != 'none' -%}
                {%- assign src = block.settings.review_source -%}
                <span class="lt-card__source lt-card__source--{{ src }}">
                  {%- case src -%}
                    {%- when 'google' -%}{{ icon_google }} Google
                    {%- when 'instagram' -%}{{ icon_instagram }} Instagram
                    {%- when 'facebook' -%}{{ icon_facebook }} Facebook
                    {%- when 'tiktok' -%}{{ icon_tiktok }} TikTok
                    {%- when 'email' -%}{{ icon_email }} Email
                    {%- when 'whatsapp' -%}{{ icon_whatsapp }} WhatsApp
                    {%- when 'youtube' -%}{{ icon_youtube }} YouTube
                    {%- else -%}{{ block.settings.custom_source }}
                  {%- endcase -%}
                </span>
              {%- endif -%}
              {%- if block.settings.show_verified -%}
                <span class="lt-card__verified">
                  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                  Verified
                </span>
              {%- endif -%}
              {%- if block.settings.product_tag != blank -%}
                <span class="lt-card__product">{{ block.settings.product_tag }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}

          <!-- Stars -->
          {%- if block.settings.show_stars and block.settings.star_count > 0 -%}
            <div class="lt-card__stars" aria-label="{{ block.settings.star_count }} out of 5 stars">
              {%- for i in (1..block.settings.star_count) -%}
                <span>★</span>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <!-- Quote icon -->
          {%- if sec.show_quote_icon -%}
            <div class="lt-card__quote-icon">"</div>
          {%- endif -%}

          <!-- Quote text -->
          {%- if block.settings.quote != blank -%}
            <p class="lt-card__text">"{{ block.settings.quote }}"</p>
          {%- endif -%}

        </div>
      {%- endfor -%}

      <!-- LOAD MORE BUTTON -->
      {%- if sec.initial_visible_cards > 0 and testi_blocks.size > sec.initial_visible_cards -%}
        <div class="lt-load-more-wrap" id="lt-load-more-wrap-{{ section.id }}">
          <button
            class="lt-load-more-btn"
            onclick="ltShowMore('{{ section.id }}')"
            aria-label="{{ sec.load_more_label }}"
          >
            {{ sec.load_more_label }}
          </button>
        </div>
      {%- endif -%}

    </div>

  </div>
</section>

{%- if sec.initial_visible_cards > 0 -%}
<script>
(function () {
  function ltShowMore(secId) {
    var hidden = document.querySelectorAll('#im-testi-' + secId + ' .lt-card--hidden');
    hidden.forEach(function (c) { c.classList.remove('lt-card--hidden'); });
    var wrap = document.getElementById('lt-load-more-wrap-' + secId);
    if (wrap) wrap.style.display = 'none';
  }
  window.ltShowMore = ltShowMore;
})();
</script>
{%- endif -%}

