{% comment %}
  In Media — Testimonials Section
  Light / white theme matching BudgetFinds store aesthetic
  Left: sticky heading + stats | Right: 2-col grid testimonial cards
  Enhanced: avatar upload, media source badge, editable text, real data fields
  v2: card shadow controls + load more / initial visible cards slider
{% endcomment %}

{%- liquid
  assign sec = section.settings
-%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap');

  #im-testi-{{ section.id }} {
    --bg:           {{ sec.bg_color }};
    --accent:       {{ sec.accent_color }};
    --heading-col:  {{ sec.heading_color }};
    --label-col:    {{ sec.label_color }};
    --body-col:     {{ sec.body_color }};
    --muted-col:    {{ sec.muted_color }};
    --card-bg:      {{ sec.card_bg }};
    --card-border:  {{ sec.card_border_color }};
    --quote-col:    {{ sec.quote_icon_color }};

    --pt: {{ sec.padding_top }}px;
    --pb: {{ sec.padding_bottom }}px;
    --pl: {{ sec.padding_left }}px;
    --pr: {{ sec.padding_right }}px;
    --mt: {{ sec.margin_top }}px;
    --mb: {{ sec.margin_bottom }}px;
    --max-w: {{ sec.max_width }}px;

    --eyebrow-sz:    {{ sec.eyebrow_size }}px;
    --heading-sz:    {{ sec.heading_size }}px;
    --desc-sz:       {{ sec.desc_size }}px;
    --name-sz:       {{ sec.name_size }}px;
    --role-sz:       {{ sec.role_size }}px;
    --quote-sz:      {{ sec.quote_size }}px;
    --quote-icon-sz: {{ sec.quote_icon_size }}px;

    --card-radius: {{ sec.card_radius }}px;
    --card-pad:    {{ sec.card_padding }}px;
    --card-gap:    {{ sec.card_gap }}px;
    --avatar-sz:   {{ sec.avatar_size }}px;
    --col-gap:     {{ sec.col_gap }}px;
    --left-w:      {{ sec.left_col_width }}%;

    background-color: var(--bg);
    margin-top:    var(--mt);
    margin-bottom: var(--mb);
  }

  #im-testi-{{ section.id }} .lt-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--pt) var(--pr) var(--pb) var(--pl);
    box-sizing: border-box;
    display: grid;
    grid-template-columns: var(--left-w) 1fr;
    gap: var(--col-gap);
    align-items: start;
  }

  /* ── LEFT PANEL ── */
  #im-testi-{{ section.id }} .lt-left {
    position: sticky;
    top: {{ sec.sticky_top }}px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #im-testi-{{ section.id }} .lt-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: var(--eyebrow-sz);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--label-col);
    padding: 6px 14px;
    border: 1px solid var(--accent);
    border-radius: 100px;
    width: fit-content;
  }

  #im-testi-{{ section.id }} .lt-heading {
    font-family: 'Inter', sans-serif;
    font-size: var(--heading-sz);
    font-weight: 700;
    color: var(--heading-col);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 0;
  }

  #im-testi-{{ section.id }} .lt-desc {
    font-family: 'Inter', sans-serif;
    font-size: var(--desc-sz);
    font-weight: 400;
    color: var(--muted-col);
    line-height: 1.65;
    margin: 0;
  }

  /* Stats */
  #im-testi-{{ section.id }} .lt-stats {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 8px;
  }

  #im-testi-{{ section.id }} .lt-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  #im-testi-{{ section.id }} .lt-stat__num {
    font-family: 'Inter', sans-serif;
    font-size: {{ sec.stat_num_size }}px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  #im-testi-{{ section.id }} .lt-stat__label {
    font-family: 'Inter', sans-serif;
    font-size: {{ sec.stat_label_size }}px;
    font-weight: 400;
    color: var(--muted-col);
    line-height: 1.4;
  }

  /* ── RIGHT PANEL — CSS Grid for even alignment ── */
  #im-testi-{{ section.id }} .lt-right {
    display: grid;
    grid-template-columns: repeat({{ sec.card_columns }}, 1fr);
    gap: var(--card-gap);
    align-items: start;
  }

  /* ── CARD ── */
  #im-testi-{{ section.id }} .lt-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: var(--card-pad);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
    {%- if sec.card_shadow_enabled -%}
    box-shadow: 0 {{ sec.card_shadow_y }}px {{ sec.card_shadow_blur }}px {{ sec.card_shadow_spread }}px rgba(0,0,0,{{ sec.card_shadow_opacity | divided_by: 100.0 }});
    {%- endif -%}
  }

  #im-testi-{{ section.id }} .lt-card:hover {
    border-color: {{ sec.accent_color }}88;
    {%- if sec.card_shadow_enabled -%}
    box-shadow: 0 {{ sec.card_shadow_y | plus: 4 }}px {{ sec.card_shadow_blur | plus: 12 }}px {{ sec.card_shadow_spread }}px rgba(0,0,0,{{ sec.card_shadow_opacity | plus: 6 | divided_by: 100.0 }}), 0 4px 20px -4px {{ sec.accent_color }}22;
    {%- else -%}
    box-shadow: 0 4px 20px -4px {{ sec.accent_color }}22;
    {%- endif -%}
  }

  /* ── HIDDEN CARD (load more) ── */
  #im-testi-{{ section.id }} .lt-card--hidden {
    display: none;
  }

  /* ── LOAD MORE BUTTON ── */
  #im-testi-{{ section.id }} .lt-load-more-wrap {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    margin-top: 8px;
  }

  #im-testi-{{ section.id }} .lt-load-more-btn {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: {{ sec.load_more_color }};
    background: transparent;
    border: 1.5px solid {{ sec.load_more_color }};
    border-radius: 100px;
    padding: 10px 28px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    letter-spacing: 0.02em;
  }

  #im-testi-{{ section.id }} .lt-load-more-btn:hover {
    background: {{ sec.load_more_color }};
    color: #ffffff;
  }

  /* Author row */
  #im-testi-{{ section.id }} .lt-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #im-testi-{{ section.id }} .lt-card__avatar {
    width: var(--avatar-sz);
    height: var(--avatar-sz);
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid {{ sec.accent_color }}33;
    background: {{ sec.avatar_fallback_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #im-testi-{{ section.id }} .lt-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #im-testi-{{ section.id }} .lt-card__avatar-initials {
    font-family: 'Inter', sans-serif;
    font-size: {{ sec.initials_size }}px;
    font-weight: 600;
    color: var(--accent);
    line-height: 1;
  }

  #im-testi-{{ section.id }} .lt-card__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  #im-testi-{{ section.id }} .lt-card__name {
    font-family: 'Inter', sans-serif;
    font-size: var(--name-sz);
    font-weight: 600;
    color: var(--heading-col);
    margin: 0;
    line-height: 1.2;
  }

  #im-testi-{{ section.id }} .lt-card__role {
    font-family: 'Inter', sans-serif;
    font-size: var(--role-sz);
    font-weight: 400;
    color: var(--muted-col);
    margin: 0;
    line-height: 1.3;
  }

  #im-testi-{{ section.id }} .lt-card__date {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 400;
    color: var(--muted-col);
    opacity: 0.7;
    margin: 0;
  }

  /* ── META ROW ── */
  #im-testi-{{ section.id }} .lt-card__meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* ── SOURCE BADGE ── */
  #im-testi-{{ section.id }} .lt-card__source {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 3px 8px;
    border-radius: 100px;
    border: 1px solid;
    width: fit-content;
    line-height: 1.4;
  }

  #im-testi-{{ section.id }} .lt-card__source svg {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    fill: currentColor;
  }

  #im-testi-{{ section.id }} .lt-card__source--google    { color: #555555; border-color: #d0d0d0; background: #f5f5f5; }
  #im-testi-{{ section.id }} .lt-card__source--instagram { color: #c13584; border-color: #f0c0d8; background: #fdf0f6; }
  #im-testi-{{ section.id }} .lt-card__source--facebook  { color: #1877f2; border-color: #bdd4fc; background: #f0f5ff; }
  #im-testi-{{ section.id }} .lt-card__source--tiktok    { color: #333333; border-color: #cccccc; background: #f7f7f7; }
  #im-testi-{{ section.id }} .lt-card__source--email     { color: #444444; border-color: #d0d0d0; background: #f5f5f5; }
  #im-testi-{{ section.id }} .lt-card__source--whatsapp  { color: #128c7e; border-color: #b2efc9; background: #f0fbf4; }
  #im-testi-{{ section.id }} .lt-card__source--youtube   { color: #cc0000; border-color: #ffb3b3; background: #fff5f5; }
  #im-testi-{{ section.id }} .lt-card__source--other     { color: #555555; border-color: #dddddd; background: #fafafa; }

  /* ── VERIFIED BADGE ── */
  #im-testi-{{ section.id }} .lt-card__verified {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    color: {{ sec.accent_color }};
  }

  #im-testi-{{ section.id }} .lt-card__verified svg {
    width: 11px;
    height: 11px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── PRODUCT TAG ── */
  #im-testi-{{ section.id }} .lt-card__product {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    color: var(--muted-col);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Stars */
  #im-testi-{{ section.id }} .lt-card__stars {
    display: flex;
    gap: 2px;
    font-size: {{ sec.star_size }}px;
    line-height: 1;
  }

  #im-testi-{{ section.id }} .lt-card__stars span {
    color: {{ sec.accent_color }};
  }

  /* Quote icon */
  #im-testi-{{ section.id }} .lt-card__quote-icon {
    font-family: Georgia, serif;
    font-size: var(--quote-icon-sz);
    font-weight: 700;
    color: var(--quote-col);
    line-height: 0.6;
    letter-spacing: -2px;
    opacity: 0.25;
    user-select: none;
  }

  /* Quote text */
  #im-testi-{{ section.id }} .lt-card__text {
    font-family: 'Inter', sans-serif;
    font-size: var(--quote-sz);
    font-weight: 400;
    font-style: italic;
    color: var(--body-col);
    line-height: 1.7;
    margin: 0;
  }

  /* ── MOBILE ── */
  @media (max-width: {{ sec.breakpoint_mobile }}px) {
    #im-testi-{{ section.id }} .lt-inner {
      grid-template-columns: 1fr;
      padding: {{ sec.mobile_pad_v }}px {{ sec.mobile_pad_h }}px;
      gap: {{ sec.mobile_col_gap }}px;
    }

    #im-testi-{{ section.id }} .lt-left { position: static; }

    #im-testi-{{ section.id }} .lt-right {
      grid-template-columns: repeat({{ sec.mobile_card_columns }}, 1fr);
    }

    #im-testi-{{ section.id }} .lt-heading {
      font-size: {{ sec.heading_size_mobile }}px;
    }

    #im-testi-{{ section.id }} .lt-card__text {
      font-size: {{ sec.quote_size_mobile }}px;
    }
  }

  /* ── TABLET ── */
  @media (max-width: {{ sec.breakpoint_tablet }}px) and (min-width: {{ sec.breakpoint_mobile | plus: 1 }}px) {
    #im-testi-{{ section.id }} .lt-inner {
      grid-template-columns: 1fr;
      padding: {{ sec.tablet_pad_v }}px {{ sec.tablet_pad_h }}px;
    }

    #im-testi-{{ section.id }} .lt-left { position: static; }

    #im-testi-{{ section.id }} .lt-right {
      grid-template-columns: repeat({{ sec.tablet_card_columns }}, 1fr);
    }

    #im-testi-{{ section.id }} .lt-heading {
      font-size: {{ sec.heading_size_tablet }}px;
    }
  }
</style>

